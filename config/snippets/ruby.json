"Short Description": {
    "prefix": "prefix",
    "body": [
      "# https://leetcode.com/problems/valid-parentheses",
      "# https://youtu.be/WTzjTskDFMg",
      "",
      "''\"",
      "20. Valid Parentheses",
      "",
      "Given a string s containing just the characters '(', ')', '{', '}', '[' and ']', determine if the input string is valid.",
      "",
      "An input string is valid if:",
      "",
      "1. Open brackets must be closed by the same type of brackets.",
      "2. Open brackets must be closed in the correct order.",
      "3. Every close bracket has a corresponding open bracket of the same type.",
      "",
      "## CONSTRAINTS",
      "",
      "    * 1 <= s.length <= 10^4 (string length is at most 10^4)",
      "    * s consists of parentheses only '()[]{}'.",
      "",
      "## HOW-TO",
      "",
      "    1. Return False for Odd-Length Strings",
      "    2. Mapping of Closing to Opening Brackets",
      "    3. Iterating Through the String",
      "    5. If the character is a closing bracket",
      "        1. if there is a corresponding opening bracket, pop it from the stack",
      "        2. If it is not, return False.",
      "    6. If the character is an opening bracket, append it to the stack.",
      "    7. Return True if the stack is empty",
      "",
      "## COMPLEXITY",
      "",
      "    - **Time Complexity**: O(n)",
      "    - **Space Complexity**: O(n)",
      "\"''",
      "",
      "def valid_parentheses(s)",
      "  return false if s.length.odd?",
      "",
      "  brackets = {",
      "    ')' => '(',",
      "    '}' => '{',",
      "    ']' => '['",
      "  }",
      "  stack = []",
      "",
      "  s.each_char do |char|",
      "    if brackets.key?(char)",
      "      return false if brackets[char] != stack.pop",
      "    else",
      "      stack.push(char)",
      "    end",
      "  end",
      "",
      "  stack.empty?",
      "end",
      "",
      "require 'test/unit'",
      "class TestScenarios < Test::Unit::TestCase",
      "  def test_scenarios",
      "    assert_equal valid_parentheses('()'), true",
      "    assert_equal valid_parentheses('()[]{}'), true",
      "    assert_equal valid_parentheses('(((())))'), true",
      "    assert_equal valid_parentheses('[()]'), true",
      "    assert_equal valid_parentheses('){'), false",
      "    assert_equal valid_parentheses(']'), false",
      "    assert_equal valid_parentheses('(]'), false",
      "    assert_equal valid_parentheses('([)]'), false",
      "    assert_equal valid_parentheses('(){}}{'), false",
      "  end",
      "end",
      ""
    ],
    "description": "Long Description"
  }  
